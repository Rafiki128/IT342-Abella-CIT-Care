<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_primary_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_launcher_foreground"
                    app:tint="@color/text_header" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="CIT-Care"
                    android:textColor="@color/text_header"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Welcome back to\nyour health\nportal"
                android:textColor="@color/text_header"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Access your medical records, schedule appointments, and connect with our healthcare professionals."
                android:textColor="@color/text_header"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_rounded_body"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Sign In"
                android:textColor="@color/text_body_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Please enter your details to continue."
                android:textColor="@color/text_body_muted"
                android:textSize="14sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Email address" android:textSize="12sp" android:textColor="@color/text_body_dark" />
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_rounded_body"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:layout_marginTop="4dp"
                android:paddingStart="12dp"
                android:textSize="14sp"
                android:backgroundTint="#F0F0F0"
                app:drawableStartCompat="@drawable/ic_email"
                app:drawableTint="@color/input_icon"
                android:drawablePadding="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Password" android:textSize="12sp" android:textColor="@color/text_body_dark" />
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_rounded_body"
                android:inputType="textPassword"
                android:layout_marginTop="4dp"
                android:hint="••••••••"
                android:paddingStart="12dp"
                android:textSize="14sp"
                android:backgroundTint="#F0F0F0"
                app:drawableStartCompat="@drawable/ic_lock"
                app:drawableTint="@color/input_icon"
                android:drawablePadding="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cbRememberMe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remember me"
                    android:textSize="12sp"
                    android:textColor="@color/text_body_dark"
                    android:buttonTint="@color/input_icon"/>

                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot password?"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_link" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/brand_primary_dark"
                android:text="Sign in →"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textAllCaps="false"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/input_border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Or continue with"
                    android:textColor="@color/text_body_muted"
                    android:textSize="12sp"
                    android:paddingHorizontal="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/input_border" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGoogleSignIn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/white"
                android:text="Sign in with Google"
                android:textColor="@color/text_body_dark"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                app:strokeColor="@color/input_border"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/input_border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?"
                    android:textColor="@color/text_body_muted"
                    android:textSize="12sp"
                    android:paddingHorizontal="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/input_border" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvGoToRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="40dp"
                android:text="Create an account now"
                android:textColor="@color/text_link"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="© 2026 CIT-Care. All rights reserved."
                android:textColor="@color/text_body_muted"
                android:textSize="10sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>